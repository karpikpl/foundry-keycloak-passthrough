# Copy to agent_v5/.env

# Full Azure AI Foundry project endpoint (required)
FOUNDRY_ENDPOINT=https://<foundry-account>.cognitiveservices.azure.com/api/projects/<project-name>

# Leena.ai MCP server URL
MCP_SERVER_URL=https://sandbox-aic.leena.ai/mcp/

# Leena.ai OAuth 2.0 endpoints
LEENA_AUTHORIZE_URL=https://sandbox-chat.leena.ai/api/oauth/authorize
LEENA_TOKEN_URL=https://sandbox-chat.leena.ai/api/oauth/token

# Leena OAuth client credentials (provided by Leena admin)
CLIENT_ID=<leena-client-id>
CLIENT_SECRET=<leena-client-secret>

# Optional: space-separated OAuth scopes (leave empty if Leena infers them)
OAUTH_SCOPE=

# Loopback callback — must match the redirect URI registered on the Leena
# OAuth client. Default matches http://127.0.0.1:8765/callback.
CALLBACK_PORT=8765
CALLBACK_PATH=/callback

# Set USE_PKCE=false if Leena's OAuth server does not accept PKCE.
USE_PKCE=true

# Model deployment name
AGENT_MODEL=gpt-4o

# Shared agent name in Foundry — every user reuses this single definition.
AGENT_NAME=cloud-helper-agent-v5
