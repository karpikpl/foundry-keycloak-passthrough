# Copy to agent_v3/.env — or run `azd deploy` to populate automatically.
# AZD env vars are loaded automatically if .azure/config.json is present.

# Full Azure AI Foundry project endpoint (required)
FOUNDRY_ENDPOINT=https://<foundry-account>.cognitiveservices.azure.com/api/projects/<project-name>

# MCP server URL (required)
MCP_SERVER_URL=https://<web-app>.azurewebsites.net/mcp

# Keycloak realm endpoints used for the local PKCE flow (required)
KEYCLOAK_BASE_URL=https://<keycloak>.azurecontainerapps.io
KEYCLOAK_REALM=mcp-demo

# Keycloak confidential client used by the desktop app
CLIENT_ID=mcp-server
CLIENT_SECRET=<keycloak-mcp-server-client-secret>

# OAuth scope requested from Keycloak (must include mcp.access for the server)
OAUTH_SCOPE=openid profile email mcp.access

# Optional: skip Keycloak's local-login UI and federate directly to Entra
# IDP_HINT=entra

# Loopback port for the OAuth callback. Must be one of the redirect URIs
# already registered on the Keycloak `mcp-server` client.
CALLBACK_PORT=55899

# Model deployment name
AGENT_MODEL=gpt-4o

# Shared agent name in Foundry — every user reuses this single definition.
AGENT_NAME=cloud-helper-agent-v3
