# Copy to agent_v2/.env — or run `azd deploy` to populate automatically.
# AZD env vars are loaded automatically if .azure/config.json is present.

# Full Azure AI Foundry project endpoint (required)
# Written automatically by `azd hooks run postdeploy`
FOUNDRY_ENDPOINT=https://<foundry-account>.cognitiveservices.azure.com/api/projects/<project-name>

# MCP server URL (required)
MCP_SERVER_URL=https://<web-app>.azurewebsites.net/mcp

# Foundry connection name for OAuth Identity Passthrough (required)
# Created by `azd provision` — e.g. cloud-helper-mcp-xxx
MCP_CONNECTION_NAME=<connection-name>

# Model deployment name (optional, default: gpt-4o)
AGENT_MODEL=gpt-4o

# Agent name in Foundry (optional, default: cloud-helper-agent)
# When using `azd deploy`, an agent with this name is created automatically.
AGENT_NAME=cloud-helper-agent
