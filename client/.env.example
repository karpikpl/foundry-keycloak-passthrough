# Copy to client/.env and fill in values, OR run 'azd deploy' to have it
# generated automatically.

# MCP endpoint. Written automatically by postdeploy; override if needed.
SERVER_URL=https://<web-app-name>.azurewebsites.net/mcp

# App registration client ID for the MCP server. Written automatically by postdeploy.
ENTRA_APP_CLIENT_ID=<server-app-registration-client-id>

# Optional explicit scope override. If omitted, test_client.py uses the first
# scopes_supported entry from protected resource metadata.
MCP_SCOPE=api://<server-app-registration-client-id>/mcp.access

# Optional public client override for CLI automation. If omitted, test_client.py
# uses ENTRA_APP_CLIENT_ID (the MCP server's own app reg, which has isFallbackPublicClient=true).
TEST_CLIENT_ID=<optional-separate-public-client-app-registration-id>
