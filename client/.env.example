# Copy to client/.env and fill in values, OR run `azd deploy` and let the
# AZD postdeploy hook write this file for you.

# MCP endpoint
SERVER_URL=https://<web-app-name>.azurewebsites.net/mcp

# Keycloak realm hosting the OAuth flow
KEYCLOAK_BASE_URL=https://<keycloak-aca-fqdn>
KEYCLOAK_REALM=mcp-demo

# Confidential Keycloak client used by the test client + Foundry. The client
# secret is generated by the AZD postprovision script and shared with the
# test client through this file.
CLIENT_ID=mcp-server
CLIENT_SECRET=<generated-by-postprovision>

# Loopback callback port — must match a registered redirect URI on the
# Keycloak client. The postprovision script registers 55899 by default.
CALLBACK_PORT=55899
